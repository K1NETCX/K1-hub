-- MÓDULO 6: SISTEMA DE MACROS AVANÇADO
-- ============================================
local MacroSystem = {
    Macros = {},
    ActiveMacros = {},
    Recording = false,
    CurrentRecording = nil,
    
    -- Tipos de ações
    ActionTypes = {
        CLICK = "click",
        KEYPRESS = "keypress",
        WAIT = "wait",
        MOUSE_MOVE = "mouse_move",
        SCROLL = "scroll"
    },
    
    -- Criar macro
    Create = function(self, name)
        local macro = {
            name = name,
            actions = {},
            created = os.time(),
            totalDuration = 0,
            loop = false,
            loopCount = 1
        }
        self.Macros[name] = macro
        return macro
    },
    
    -- Iniciar gravação
    StartRecording = function(self, macroName)
        local macro = self.Macros[macroName]
        if not macro then
            macro = self:Create(macroName)
        end
        
        self.Recording = true
        self.CurrentRecording = macro
        macro.actions = {}
        macro.startTime = os.clock()
        
        -- Conectar eventos
        local connections = {}
        
        connections.mouseClick = game:GetService("UserInputService").InputBegan:Connect(function(input)
            if self.Recording and input.UserInputType == Enum.UserInputType.MouseButton1 then
                local elapsed = os.clock() - macro.startTime
                table.insert(macro.actions, {
                    type = self.ActionTypes.CLICK,
                    time = elapsed,
                    position = game:GetService("UserInputService"):GetMouseLocation()
                })
            end
        end)
        
        connections.keyPress = game:GetService("UserInputService").InputBegan:Connect(function(input)
            if self.Recording and input.KeyCode ~= Enum.KeyCode.Unknown then
                local elapsed = os.clock() - macro.startTime
                table.insert(macro.actions, {
                    type = self.ActionTypes.KEYPRESS,
                    time = elapsed,
                    key = input.KeyCode
                })
            end
        end)
        
        self.CurrentRecording.connections = connections
        return macro
    end,
    
    -- Parar gravação
    StopRecording = function(self)
        if self.Recording and self.CurrentRecording then
            self.Recording = false
            
            -- Desconectar eventos
            if self.CurrentRecording.connections then
                for _, conn in pairs(self.CurrentRecording.connections) do
                    conn:Disconnect()
                end
            end
            
            -- Calcular duração total
            local totalDuration = 0
            for _, action in ipairs(self.CurrentRecording.actions) do
                if action.time > totalDuration then
                    totalDuration = action.time
                end
            end
            self.CurrentRecording.totalDuration = totalDuration
            
            -- Salvar macro
            self:SaveMacro(self.CurrentRecording.name)
            self.CurrentRecording = nil
            return true
        end
        return false
    end,
    
    -- Executar macro
    Play = function(self, macroName, loop)
        local macro = self.Macros[macroName]
        if not macro or #macro.actions == 0 then
            return false
        end
        
        local isPlaying = true
        local loopCount = loop and -1 or 1
        
        local thread = coroutine.create(function()
            local loopIteration = 0
            while isPlaying and (loopCount == -1 or loopIteration < loopCount) do
                local startTime = tick()
                
                for _, action in ipairs(macro.actions) do
                    if not isPlaying then break end
                    
                    -- Aguardar até o tempo da ação
                    local waitTime = action.time - (tick() - startTime)
                    if waitTime > 0 then
                        task.wait(waitTime)
                    end
                    
                    -- Executar ação
                    if action.type == self.ActionTypes.CLICK then
                        -- Simular clique
                        local mouse = game:GetService("Players").LocalPlayer:GetMouse()
                        mouse.Button1Down:Fire()
                        task.wait(0.05)
                        mouse.Button1Up:Fire()
                    elseif action.type == self.ActionTypes.KEYPRESS then
                        -- Simular tecla
                        game:GetService("VirtualInputManager"):SendKeyEvent(true, action.key, false, game)
                        task.wait(0.05)
                        game:GetService("VirtualInputManager"):SendKeyEvent(false, action.key, false, game)
                    end
                end
                
                loopIteration = loopIteration + 1
            end
        end)
        
        coroutine.resume(thread)
        self.ActiveMacros[macroName] = thread
        return true
    end,
    
    -- Parar macro
    Stop = function(self, macroName)
        if self.ActiveMacros[macroName] then
            self.ActiveMacros[macroName] = nil
            return true
        end
        return false
    end,
    
    -- Salvar macro
    SaveMacro = function(self, macroName)
        local macro = self.Macros[macroName]
        if macro then
            local encoded = game:GetService("HttpService"):JSONEncode(macro)
            FileSystem:Save("macros/" .. macroName .. ".macro", encoded, true)
        end
    end,
    
    -- Carregar macros
    LoadMacros = function(self)
        local files = FileSystem:List("macros")
        for _, file in ipairs(files) do
            if string.match(file, "%.macro$") then
                local data = FileSystem:Load("macros/" .. file, true)
                if data then
                    local macro = game:GetService("HttpService"):JSONDecode(data)
                    if macro then
                        self.Macros[macro.name] = macro
                    end
                end
            end
        end
    end
}

