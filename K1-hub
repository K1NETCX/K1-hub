        MEMORY_SCAN = {name = "Escaneamento de Memória", weight = 35},
        BEHAVIOR_ANALYSIS = {name = "Análise de Comportamento", weight = 20},
        ANTICHEAT = {name = "Anti-Cheat Detectado", weight = 100}
    },
    
    -- Inicializar anti-ban
    Initialize = function(self)
        if not self.Enabled then return end
        
        -- Configurar bypasses
        self:SetupBypasses()
        
        -- Iniciar monitoramento
        self:StartMonitoring()
        
        MessageSystem:Info(GlobalConfig.Messages.AntiBanActive)
    end,
    
    -- Configurar métodos de bypass
    SetupBypasses = function(self)
        -- Bypass para RemoteEvents
        self.BypassMethods.remoteEvent = function(remote)
            local oldFire = remote.FireServer
            remote.FireServer = function(...)
                if self.DetectionScore < 80 then
                    oldFire(...)
                end
            end
        end
        
        -- Bypass para checagens de admin
        self.BypassMethods.adminCheck = function()
            local players = game:GetService("Players")
            local localPlayer = players.LocalPlayer
            
            -- Espelhar informações do jogador
            local oldGetPlayer = players.GetPlayer
            players.GetPlayer = function(self, userId)
                if userId == localPlayer.UserId then
                    return nil
                end
                return oldGetPlayer(self, userId)
            end
        end
        
        -- Bypass para logs
        self.BypassMethods.logs = function()
            local oldWarn = warn
            local oldPrint = print
            local oldError = error
            
            warn = function(...)
                local msg = tostring(...)
                if not string.find(msg, "exploit") and not string.find(msg, "hack") then
                    oldWarn(...)
                end
            end
            
            print = function(...)
                local msg = tostring(...)
                if not string.find(msg, "detected") then
                    oldPrint(...)
                end
            end
        end
    end,
    
    -- Iniciar monitoramento
    StartMonitoring = function(self)
        -- Monitorar RemoteEvents suspeitos
        local function monitorRemotes()
            for _, remote in ipairs(game:GetDescendants()) do
                if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
                    if string.find(remote.Name:lower(), "admin") or
                       string.find(remote.Name:lower(), "check") or
                       string.find(remote.Name:lower(), "detect") then
                        self:AddThreat(self.ThreatTypes.ADMIN_CHECK)
                    end
                end
            end
        end
        
        -- Monitorar mudanças no Workspace
        workspace.DescendantAdded:Connect(function(descendant)
            if descendant:IsA("Script") or descendant:IsA("LocalScript") then
                if string.find(descendant.Name:lower(), "anticheat") or
                   string.find(descendant.Name:lower(), "anti-cheat") then
                    self:AddThreat(self.ThreatTypes.ANTICHEAT)
                    descendant.Disabled = true
                end
            end
        end)
        
        -- Monitorar kicks
        local oldKick = game:GetService("Players").LocalPlayer.Kick
        game:GetService("Players").LocalPlayer.Kick = function(reason)
            if self.DetectionScore < 90 then
                self:AddThreat(self.ThreatTypes.ADMIN_CHECK, 50)
                return
            end
            oldKick(reason)
        end
        
        -- Iniciar loops de monitoramento
        coroutine.wrap(function()
            while self.Enabled do
                monitorRemotes()
                task.wait(5)
            end
        end)()
    end,
    
    -- Adicionar ameaça
    AddThreat = function(self, threatType, customWeight)
        local weight = customWeight or threatType.weight
        self.DetectionScore = math.min(100, self.DetectionScore + weight)
        
        table.insert(self.Threats, {
            type = threatType.name,
            weight = weight,
            timestamp = os.time(),
            score = self.DetectionScore
        })
        
        if self.DetectionScore >= 70 then
            MessageSystem:Warning(string.format(GlobalConfig.Messages.ThreatDetected, threatType.name))
        end
        
        if self.DetectionScore >= 90 then
            self:EmergencyProtocol()
        end
        
        return self.DetectionScore
    end,
    
    -- Protocolo de emergência
    EmergencyProtocol = function(self)
        MessageSystem:Warning(GlobalConfig.Messages.ThreatBlocked)
        
        -- Limpar evidências
        self:CleanEvidence()
        
        -- Desativar scripts suspeitos
        for _, script in ipairs(game:GetDescendants()) do
            if script:IsA("Script") and script.Name:match("cheat|hack|exploit") then
                script.Disabled = true
            end
        end
        
        -- Esconder GUI
        if RayfieldLibrary then
            RayfieldLibrary:SetVisibility(false)
        end
        
        -- Aguardar e restaurar
        task.wait(30)
        self.DetectionScore = 0
        if RayfieldLibrary then
            RayfieldLibrary:SetVisibility(true)
        end
    end,
    
    -- Limpar evidências
    CleanEvidence = function(self)
        -- Limpar console
        local console = game:GetService("CoreGui"):FindFirstChild("RobloxGui")
        if console then
            for _, child in ipairs(console:GetChildren()) do
                if child.Name:match("Log") then
                    child:Destroy()
                end
            end
        end
        
        -- Limpar variáveis
        local blacklistedVars = {"executor", "exploit", "hack", "cheat"}
        for _, var in ipairs(blacklistedVars) do
            if _G[var] then
                _G[var] = nil
            end
        end
    end,
    
    -- Verificar segurança
    CheckSecurity = function(self)
        return self.DetectionScore < 50
    end
}

