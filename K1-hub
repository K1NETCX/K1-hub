-- ============================================
-- MÓDULO 12: INICIALIZAÇÃO DO SISTEMA
-- ============================================
local SystemInitializer = {
    -- Inicializar tudo
    Initialize = function(self)
        print("╔═══════════════════════════════════════════════════════════════╗")
        print("║     " .. GlobalConfig.HubInfo.Name .. " v" .. GlobalConfig.HubInfo.Version .. "     ║")
        print("║     Inicializando sistema completo...                         ║")
        print("╚═══════════════════════════════════════════════════════════════╝")
        
        -- Inicializar sistemas
        FileSystem:Initialize()
        UserConfig:Load()
        AntiBanSystem:Initialize()
        AnalyticsSystem:Initialize()
        MacroSystem:LoadMacros()
        ScriptSystem:LoadHistory()
        
        -- Verificar key system
        if not KeySystem:LoadSavedKey() then
            -- Mostrar UI de key
            KeySystem:ShowKeyUI(function(success)
                if success then
                    self:CompleteInitialization()
                end
            end)
        else
            self:CompleteInitialization()
        end
    end,
    
    -- Completar inicialização
    CompleteInitialization = function(self)
        -- Verificar atualizações
        if UpdateSystem:CheckForUpdates() then
            MessageSystem:Info(string.format(GlobalConfig.Messages.UpdateAvailable, UpdateSystem.AvailableVersion))
        end
        
        -- Construir interface
        local window = InterfaceBuilder:Build()
        
        if window then
            MessageSystem:Success(GlobalConfig.Messages.HubStarted)
            
            -- Mensagem de boas-vindas
            task.wait(2)
            MessageSystem:Welcome(game:GetService("Players").LocalPlayer.Name)
            
            -- Registrar scripts built-in
            for category, scripts in pairs(BuiltInScripts) do
                for scriptName, scriptData in pairs(scripts) do
                    ScriptSystem:Register(scriptData)
                end
            end
            
            return window
        else
            warn("Falha ao inicializar hub")
            return nil
        end
    end
}

-- ============================================
-- EXPORTAR FUNÇÕES GLOBAIS PARA MODIFICAÇÃO
-- ============================================
_G.UltimateHub = {
    -- Sistemas principais
    Config = GlobalConfig,
    KeySystem = KeySystem,
    AntiBan = AntiBanSystem,
    MacroSystem = MacroSystem,
    ScriptSystem = ScriptSystem,
    FileSystem = FileSystem,
    UpdateSystem = UpdateSystem,
    Analytics = AnalyticsSystem,
    Encryption = EncryptionSystem,
    Interface = InterfaceBuilder,
    
    -- Funções úteis
    Notify = function(title, content, duration)
        MessageSystem:Notify(title, content, duration)
    end,
    
    Success = function(content)
        MessageSystem:Success(content)
    end,
    
    Error = function(content)
        MessageSystem:Error(content)
    end,
    
    Warning = function(content)
        MessageSystem:Warning(content)
    end,
    
    Info = function(content)
        MessageSystem:Info(content)
    end,
    
    -- Criar script personalizado
    CreateScript = function(name, description, category, func, requiredFeature)
        ScriptSystem:Register({
            name = name,
            description = description,
            category = category,
            type = "function",
            function = func,
            requiredFeature = requiredFeature or "all_scripts"
        })
    end,
    
    -- Criar macro
    CreateMacro = function(name)
        return MacroSystem:Create(name)
    end,
    
    -- Modificar configurações
    SetConfig = function(key, value)
        local keys = string.split(key, ".")
        local target = GlobalConfig
        for i = 1, #keys - 1 do
            target = target[keys[i]]
            if not target then return false end
        end
        target[keys[#keys]] = value
        return true
    end,
    
    -- Obter versão
    GetVersion = function()
        return GlobalConfig.HubInfo.Version
    end,
    
    -- Reiniciar hub
    Restart = function()
        MessageSystem:Info("Reiniciando hub...")
        task.wait(1)
        if InterfaceBuilder.MainWindow then
            InterfaceBuilder.MainWindow:Destroy()
        end
        task.wait(0.5)
        SystemInitializer:Initialize()
    end,
    
    -- Desligar hub
    Shutdown = function()
        MessageSystem:Info("Desligando hub...")
        task.wait(1)
        if InterfaceBuilder.MainWindow then
            InterfaceBuilder.MainWindow:Destroy()
        end
        AnalyticsSystem:FlushEvents()
    end
}

-- ============================================
-- INICIAR O HUB
-- ============================================
SystemInitializer:Initialize()

-- ============================================
-- RETORNAR PARA USO
-- ============================================
