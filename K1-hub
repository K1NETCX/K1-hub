-- MÓDULO 3: SISTEMA DE ARQUIVOS AVANÇADO
-- ============================================
local FileSystem = {
    BasePath = GlobalConfig.HubInfo.Name .. "_Data",
    CachePath = GlobalConfig.HubInfo.Name .. "_Cache",
    BackupPath = GlobalConfig.HubInfo.Name .. "_Backups",
    
    -- Inicializar sistema de arquivos
    Initialize = function(self)
        if not (isfolder and makefolder and writefile and readfile and isfile) then
            warn("Sistema de arquivos não disponível")
            return false
        end
        
        -- Criar pastas necessárias
        local folders = {self.BasePath, self.CachePath, self.BackupPath}
        for _, folder in ipairs(folders) do
            if not isfolder(folder) then
                makefolder(folder)
            end
        end
        
        return true
    end,
    
    -- Salvar arquivo
    Save = function(self, path, data, encrypted)
        local fullPath = self.BasePath .. "/" .. path
        local content = data
        
        if encrypted then
            content = EncryptionSystem:Encrypt(content)
        end
        
        local success, err = pcall(function()
            writefile(fullPath, content)
        end)
        
        if not success then
            warn("Erro ao salvar arquivo: " .. tostring(err))
            return false
        end
        return true
    end,
    
    -- Carregar arquivo
    Load = function(self, path, encrypted)
        local fullPath = self.BasePath .. "/" .. path
        
        if not isfile(fullPath) then
            return nil
        end
        
        local success, content = pcall(function()
            return readfile(fullPath)
        end)
        
        if not success then
            warn("Erro ao carregar arquivo: " .. tostring(content))
            return nil
        end
        
        if encrypted then
            content = EncryptionSystem:Decrypt(content)
        end
        
        return content
    end,
    
    -- Deletar arquivo
    Delete = function(self, path)
        local fullPath = self.BasePath .. "/" .. path
        
        if isfile(fullPath) then
            local success, err = pcall(function()
                delfile(fullPath)
            end)
            return success
        end
        return false
    end,
    
    -- Listar arquivos
    List = function(self, folder)
        local fullPath = self.BasePath .. "/" .. (folder or "")
        if isfolder(fullPath) then
            local success, files = pcall(function()
                return listfiles(fullPath)
            end)
            if success then
                return files
            end
        end
        return {}
    end,
    
    -- Criar backup
    CreateBackup = function(self, name)
        local timestamp = os.time()
        local backupName = name .. "_" .. timestamp .. ".bak"
        local backupPath = self.BackupPath .. "/" .. backupName
        
        -- Salvar configurações atuais
        local configData = {
            timestamp = timestamp,
            config = UserConfig.Settings,
            global = GlobalConfig,
            timestamp_readable = os.date("%Y-%m-%d %H:%M:%S", timestamp)
        }
        
        local encoded = game:GetService("HttpService"):JSONEncode(configData)
        local success = self:Save(backupPath, encoded, true)
        
        if success then
            return backupName
        end
        return nil
    end,
    
    -- Restaurar backup
    RestoreBackup = function(self, backupName)
        local backupPath = self.BackupPath .. "/" .. backupName
        local data = self:Load(backupPath, true)
        
        if data then
            local decoded = game:GetService("HttpService"):JSONDecode(data)
            if decoded and decoded.config then
                UserConfig.Settings = decoded.config
                UserConfig:Save()
                return true
            end
        end
        return false
    end
}

