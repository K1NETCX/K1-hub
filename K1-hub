            function = function()
                local function executeCommand(command)
                    -- Tentar diferentes métodos de execução no servidor
                    local methods = {
                        function() -- Método 1: RemoteEvent
                            local remote = game:GetService("ReplicatedStorage"):FindFirstChild("AdminCommand")
                            if remote then
                                remote:FireServer(command)
                                return true
                            end
                        end,
                        function() -- Método 2: Chat
                            game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(command, "All")
                            return true
                        end,
                        function() -- Método 3: BindableEvent
                            local bindable = game:GetService("ReplicatedStorage"):FindFirstChild("Command")
                            if bindable then
                                bindable:Fire(command)
                                return true
                            end
                        end
                    }
                    
