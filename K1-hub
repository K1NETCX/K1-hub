                -- CreateSlider
                CreateSlider = function(self, config)
                    local Slider = {
                        Min = config.Range[1] or 0,
                        Max = config.Range[2] or 100,
                        Value = config.CurrentValue or 50,
                        Frame = Utility:Create("Frame", {
                            Parent = Section.Container,
