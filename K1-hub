local RayfieldStyle = {}
RayfieldStyle.__index = RayfieldStyle

function RayfieldStyle.new(config)
    local self = setmetatable({}, RayfieldStyle)
    
    -- Configurações padrão
    self.Config = {
        Name = config.Name or "Rayfield UI",
        LoadingTitle = config.LoadingTitle or "Rayfield",
        LoadingSubtitle = config.LoadingSubtitle or "Interface Suite",
        ConfigurationSaving = config.ConfigurationSaving or {
            Enabled = false,
            FolderName = "Rayfield",
            FileName = "Config"
        },
        KeySystem = config.KeySystem or false,
        Key = config.Key or "",
        Discord = config.Discord or {
            Enabled = false,
            Invite = ""
        }
    }
    
    -- Cores do tema
    self.Colors = {
        Background = Color3.fromRGB(25, 25, 30),
        Secondary = Color3.fromRGB(35, 35, 40),
        Tertiary = Color3.fromRGB(45, 45, 50),
        Accent = Color3.fromRGB(100, 150, 255),
        AccentDark = Color3.fromRGB(80, 120, 220),
        Text = Color3.fromRGB(255, 255, 255),
        SubText = Color3.fromRGB(180, 180, 185),
        Border = Color3.fromRGB(50, 50, 55)
    }
    
    -- Criar ScreenGui
    self.ScreenGui = Utility:Create("ScreenGui", {
        Name = "Rayfield",
        Parent = Services.CoreGui,
        IgnoreGuiInset = true,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    })
    
    -- Proteger GUI
    if syn and syn.protect_gui then
        syn.protect_gui(self.ScreenGui)
    elseif gethui then
        self.ScreenGui.Parent = gethui()
    end
    
    -- Loading Screen
    if config.LoadingTitle then
        self:CreateLoadingScreen()
    end
    
    self.Windows = {}
    self.Tabs = {}
    self.Notifications = {}
    
    return self
end

function RayfieldStyle:CreateLoadingScreen()
    local LoadingFrame = Utility:Create("Frame", {
        Parent = self.ScreenGui,
        BackgroundColor3 = self.Colors.Background,
        BorderSizePixel = 0,
        Position = {0, 0, 0, 0},
        Size = {1, 0, 1, 0}
    })
    
    Utility:Create("UICorner", {
        Parent = LoadingFrame,
        CornerRadius = UDim.new(0, 8)
    })
    
    Utility:Create("TextLabel", {
        Parent = LoadingFrame,
        BackgroundTransparency = 1,
        Position = {0, 0, 0.3, 0},
        Size = {1, 0, 0, 40},
        Text = self.Config.LoadingTitle,
        TextColor3 = self.Colors.Text,
        Font = Enum.Font.GothamBold,
        TextSize = 24
    })
    
    Utility:Create("TextLabel", {
        Parent = LoadingFrame,
        BackgroundTransparency = 1,
        Position = {0, 0, 0.4, 0},
        Size = {1, 0, 0, 20},
        Text = self.Config.LoadingSubtitle,
        TextColor3 = self.Colors.SubText,
