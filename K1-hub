                -- CreateKeybind
                CreateKeybind = function(self, config)
                    local Keybind = {
                        Value = config.CurrentKeybind or Enum.KeyCode.Unknown,
                        Binding = false,
                        Frame = Utility:Create("Frame", {
                            Parent = Section.Container,
                            BackgroundTransparency = 1,
                            Size = {1, 0, 0, 40}
                        })
                    }
                    
                    Utility:Create("TextLabel", {
                        Parent = Keybind.Frame,
                        BackgroundTransparency = 1,
                        Position = {0, 0, 0, 0},
                        Size = {0.4, 0, 1, 0},
                        Text = config.Name,
                        TextColor3 = self.Colors.Text,
                        Font = Enum.Font.Gotham,
                        TextSize = 14,
                        TextXAlignment = Enum.TextXAlignment.Left
                    })
                    
                    local KeybindButton = Utility:Create("TextButton", {
                        Parent = Keybind.Frame,
                        BackgroundColor3 = self.Colors.Tertiary,
                        BorderSizePixel = 0,
                        Position = {0.4, 10, 0.5, -15},
                        Size = {0.6, -20, 0, 30},
                        Text = Keybind.Value.Name,
                        TextColor3 = self.Colors.Text,
                        Font = Enum.Font.Gotham,
                        TextSize = 14
                    })
                    
                    Utility:Create("UICorner", {
                        Parent = KeybindButton,
                        CornerRadius = UDim.new(0, 4)
                    })
                    
                    KeybindButton.MouseButton1Click:Connect(function()
                        Keybind.Binding = true
                        KeybindButton.Text = "..."
                        
                        local connection
                        connection = Services.UserInputService.InputBegan:Connect(function(input, gameProcessed)
                            if Keybind.Binding and not gameProcessed then
                                if input.UserInputType == Enum.UserInputType.Keyboard then
                                    Keybind.Value = input.KeyCode
                                elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
                                    Keybind.Value = Enum.UserInputType.MouseButton1
                                elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
                                    Keybind.Value = Enum.UserInputType.MouseButton2
                                end
                                
                                KeybindButton.Text = tostring(Keybind.Value):gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", "")
                                Keybind.Binding = false
                                connection:Disconnect()
                                
                                if config.Callback then
                                    config.Callback(Keybind.Value)
                                end
                            end
                        end)
                    end)
                    
                    Services.UserInputService.InputBegan:Connect(function(input, gameProcessed)
                        if not gameProcessed and input.KeyCode == Keybind.Value then
                            if config.Callback then
                                config.Callback(Keybind.Value)
                            end
                        end
                    end)
                    
                    return Keybind
                end,
                
                -- CreateLabel
                CreateLabel = function(self, config)
                    local Label = Utility:Create("Frame", {
                        Parent = Section.Container,
                        BackgroundTransparency = 1,
                        Size = {1, 0, 0, 25}
                    })
                    
                    Utility:Create("TextLabel", {
                        Parent = Label,
                        BackgroundTransparency = 1,
                        Size = {1, 0, 1, 0},
                        Text = config.Text,
                        TextColor3 = self.Colors.Text,
                        Font = Enum.Font.Gotham,
                        TextSize = 14,
                        TextXAlignment = Enum.TextXAlignment.Left
                    })
                    
                    return Label
                end,
                
                -- CreateParagraph
                CreateParagraph = function(self, config)
                    local Paragraph = Utility:Create("Frame", {
                        Parent = Section.Container,
                        BackgroundTransparency = 1,
                        Size = {1, 0, 0, 0},
                        AutomaticSize = Enum.AutomaticSize.Y
                    })
                    
                    Utility:Create("TextLabel", {
                        Parent = Paragraph,
                        BackgroundTransparency = 1,
                        Position = {0, 0, 0, 0},
                        Size = {1, 0, 0, 20},
                        Text = config.Title or "",
                        TextColor3 = self.Colors.Text,
                        Font = Enum.Font.GothamBold,
                        TextSize = 14,
                        TextXAlignment = Enum.TextXAlignment.Left
                    })
                    
                    Utility:Create("TextLabel", {
                        Parent = Paragraph,
                        BackgroundTransparency = 1,
                        Position = {0, 0, 0, 25},
                        Size = {1, 0, 0, 0},
                        Text = config.Content or "",
                        TextColor3 = self.Colors.SubText,
                        Font = Enum.Font.Gotham,
                        TextSize = 12,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        TextWrapped = true,
                        AutomaticSize = Enum.AutomaticSize.Y
                    })
                    
                    return Paragraph
                end
            }
            
            -- Bind self to methods
            for name, method in pairs(SectionMethods) do
                SectionMethods[name] = function(...)
                    return method(self, ...)
                end
            end
            
            return SectionMethods
        end
        
        -- Set first tab as active
        if #Window.Tabs == 0 then
            Tab.Content.Visible = true
            Tab.Button.BackgroundColor3 = self.Colors.Accent
            Window.ActiveTab = Tab
        end
        
        table.insert(Window.Tabs, Tab)
        
        -- Update canvas size
        local totalHeight = (#Window.Tabs * 40) + (#Window.Tabs - 1) * 5
        Window.TabButtons.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
        
        return Tab
    end
    
    table.insert(self.Windows, Window)
    return Window
end

-- Notifications (sintaxe Rayfield)
function RayfieldStyle:Notify(config)
    local Title = config.Title or "Notification"
    local Content = config.Content or ""
    local Duration = config.Duration or 3
    local Type = config.Type or "Info"
    
    local yOffset = 10 + (#self.Notifications * 70)
    
    local NotificationFrame = Utility:Create("Frame", {
        Parent = self.ScreenGui,
        BackgroundColor3 = self.Colors.Secondary,
        BorderSizePixel = 0,
        Position = {1, -310, 0, yOffset},
        Size = {0, 300, 0, 60},
        AnchorPoint = {1, 0},
        ZIndex = 100
    })
    
    Utility:Create("UICorner", {
        Parent = NotificationFrame,
        CornerRadius = UDim.new(0, 6)
    })
    
    local typeColors = {
        Info = Color3.fromRGB(80, 160, 255),
        Success = Color3.fromRGB(80, 200, 120),
        Warning = Color3.fromRGB(255, 200, 50),
        Error = Color3.fromRGB(255, 80, 80)
    }
    
    Utility:Create("Frame", {
        Parent = NotificationFrame,
        BackgroundColor3 = typeColors[Type] or typeColors.Info,
        BorderSizePixel = 0,
        Size = {0, 4, 1, 0}
    })
    
    Utility:Create("TextLabel", {
        Parent = NotificationFrame,
        BackgroundTransparency = 1,
        Position = {0, 10, 0, 5},
        Size = {1, -20, 0, 20},
        Text = Title,
        TextColor3 = self.Colors.Text,
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left
    })
    
    Utility:Create("TextLabel", {
        Parent = NotificationFrame,
        BackgroundTransparency = 1,
        Position = {0, 10, 0, 30},
        Size = {1, -20, 0, 20},
        Text = Content,
        TextColor3 = self.Colors.SubText,
        Font = Enum.Font.Gotham,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true
    })
    
    local Notification = {Frame = NotificationFrame}
    table.insert(self.Notifications, Notification)
    
    -- Auto remove
    task.delay(Duration, function()
        if NotificationFrame then
            Utility:Tween(NotificationFrame, {
                Position = UDim2.new(1, 10, 0, NotificationFrame.Position.Y.Offset),
                BackgroundTransparency = 1
            }, 0.3)
            
            task.wait(0.3)
            NotificationFrame:Destroy()
            
            -- Remove from table
            for i, notif in ipairs(self.Notifications) do
                if notif == Notification then
                    table.remove(self.Notifications, i)
                    break
                end
            end
            
            -- Reposition
            for i, notif in ipairs(self.Notifications) do
                local newY = 10 + ((i - 1) * 70)
                Utility:Tween(notif.Frame, {
                    Position = UDim2.new(1, -310, 0, newY)
                }, 0.3)
            end
        end
    end)
end

-- Destroy Interface
function RayfieldStyle:Destroy()
    if self.ScreenGui then
        self.ScreenGui:Destroy()
    end
end

