-- MÓDULO 8: SISTEMA DE AUTO-UPDATE
-- ============================================
local UpdateSystem = {
    CurrentVersion = GlobalConfig.HubInfo.Version,
    AvailableVersion = nil,
    UpdateInfo = nil,
    AutoUpdate = GlobalConfig.Network.AutoUpdate,
    
    -- Verificar atualizações
    CheckForUpdates = function(self)
        if not self.AutoUpdate then return end
        
        local success, response = pcall(function()
            return game:HttpGet(GlobalConfig.Network.UpdateURL)
        end)
        
        if success and response then
            local data = game:GetService("HttpService"):JSONDecode(response)
            if data and data.version then
                self.AvailableVersion = data.version
                self.UpdateInfo = data
                
                if self:IsNewerVersion(self.AvailableVersion, self.CurrentVersion) then
                    MessageSystem:Info(string.format(GlobalConfig.Messages.UpdateAvailable, self.AvailableVersion))
                    return true
                end
            end
        end
        return false
    end,
    
    -- Comparar versões
    IsNewerVersion = function(self, newVersion, currentVersion)
        local newParts = {}
        for part in string.gmatch(newVersion, "[^.]+") do
            table.insert(newParts, tonumber(part) or 0)
        end
        
        local currentParts = {}
        for part in string.gmatch(currentVersion, "[^.]+") do
            table.insert(currentParts, tonumber(part) or 0)
        end
        
        for i = 1, math.max(#newParts, #currentParts) do
            local new = newParts[i] or 0
            local current = currentParts[i] or 0
            if new > current then
                return true
            elseif new < current then
                return false
            end
        end
        return false
    end,
    
    -- Aplicar atualização
    ApplyUpdate = function(self, callback)
        if not self.UpdateInfo or not self.UpdateInfo.download_url then
            return false
        end
        
        MessageSystem:Info("Baixando atualização...")
        
        local success, content = pcall(function()
            return game:HttpGet(self.UpdateInfo.download_url)
        end)
        
        if success and content then
            -- Salvar versão antiga como backup
            local oldVersionFile = "backup_v" .. self.CurrentVersion .. ".lua"
            FileSystem:Save(oldVersionFile, content, true)
            
            -- Aplicar nova versão
            local newScript = loadstring(content)
            if newScript then
                MessageSystem:Success("Atualização aplicada! Reiniciando...")
                task.wait(2)
                
                if callback then
                    callback()
                else
                    -- Reiniciar hub
                    if RayfieldLibrary then
                        RayfieldLibrary:Destroy()
                    end
                    task.wait(1)
                    newScript()
                end
                return true
            end
        end
        
        MessageSystem:Error("Falha ao aplicar atualização")
        return false
    end
}

