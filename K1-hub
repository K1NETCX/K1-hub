    -- Validar chave
    ValidateKey = function(self, key)
        -- Verificar bloqueio temporário
        if self.BlockedUntil and self.BlockedUntil > os.time() then
            local remaining = math.ceil((self.BlockedUntil - os.time()) / 60)
            return false, "Chave bloqueada por " .. remaining .. " minutos"
        end
        
        -- Verificar formato da chave
        if not key or #key < 10 then
            return false, "Chave inválida"
        end
        
        -- Verificar contra lista de chaves válidas
        local validKeys = {
            -- Formato: ["chave"] = {type = "premium", duration = 90, features = {}}
            ["FREE-2024-ABCD"] = {type = "free", duration = 30},
            ["PREMIUM-2024-EFGH"] = {type = "premium", duration = 90},
            ["VIP-2024-IJKL"] = {type = "vip", duration = 365},
            ["K1NETCX"] = {type = "developer", duration = 9999}
        }
        
        -- Verificar chave offline
        if validKeys[key] then
            local keyData = validKeys[key]
            self.KeyType = keyData.type
            self.ExpirationDate = os.time() + (keyData.duration * 86400)
            self.Features = self.KeyTypes[self.KeyType].features
            self.Status = "valid"
            self.CurrentKey = key
            return true, "Chave válida!"
        end
        
        -- Tentar verificar online
        if GlobalConfig.Network.LicenseURL then
            local success, response = pcall(function()
                return game:HttpGet(GlobalConfig.Network.LicenseURL .. "?key=" .. key .. "&hwid=" .. self:GetHWID())
            end)
            
            if success and response then
                local data = game:GetService("HttpService"):JSONDecode(response)
                if data and data.valid then
                    self.KeyType = data.type
                    self.ExpirationDate = data.expiration
                    self.Features = data.features
                    self.Status = "valid"
                    self.CurrentKey = key
                    return true, "Chave válida!"
                end
            end
        end
        
        self.Attempts = self.Attempts + 1
        if self.Attempts >= self.MaxAttempts then
            self.BlockedUntil = os.time() + 300 -- Bloquear por 5 minutos
        end
        
        return false, string.format("Chave inválida! Tentativas: %d/%d", self.Attempts, self.MaxAttempts)
    end,
    
    -- Verificar se feature está disponível
    HasFeature = function(self, feature)
        if self.Status ~= "valid" then
            return false
        end
        
        if feature == "all_features" then
            return true
        end
        
        for _, f in ipairs(self.Features) do
            if f == feature or f == "all_features" then
                return true
            end
        end
        return false
    end,
    
    -- Verificar se chave expirou
    IsExpired = function(self)
        if not self.ExpirationDate then
            return true
        end
        return os.time() > self.ExpirationDate
    end,
    
    -- Obter HWID do usuário
    GetHWID = function(self)
        local success, result = pcall(function()
            if game:GetService("RbxAnalyticsService"):GetClientId() then
                return game:GetService("RbxAnalyticsService"):GetClientId()
            end
            return tostring(game:GetService("HttpService"):GenerateGUID(false))
        end)
        return success and result or "UnknownHWID"
    end,
    
    -- Salvar chave
    SaveKey = function(self)
        if self.CurrentKey then
            local keyData = {
                key = self.CurrentKey,
                type = self.KeyType,
                expiration = self.ExpirationDate,
                saved_at = os.time()
            }
            local encoded = game:GetService("HttpService"):JSONEncode(keyData)
            FileSystem:Save("license.key", encoded, true)
            return true
        end
        return false
    end,
    
