                                ZIndex = 10
                            })
                            
                            OptionButton.MouseButton1Click:Connect(function()
                                Dropdown.Value = option
                                DropdownButton.Text = option
                                OptionContainer.Visible = false
                                OptionContainer.Size = UDim2.new(0.6, -20, 0, 0)
                                
                                if config.Callback then
                                    config.Callback(option)
                                end
                            end)
                            
                            totalHeight = totalHeight + 30
                        end
                        
                        OptionContainer.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
                    end
                    
                    updateOptions()
                    
                    DropdownButton.MouseButton1Click:Connect(function()
                        OptionContainer.Visible = not OptionContainer.Visible
                        if OptionContainer.Visible then
                            OptionContainer.Size = UDim2.new(0.6, -20, 0, math.min(#Dropdown.Options * 30, 150))
                        else
                            OptionContainer.Size = UDim2.new(0.6, -20, 0, 0)
                        end
                    end)
                    
                    function Dropdown:Set(option)
                        if table.find(Dropdown.Options, option) then
                            Dropdown.Value = option
                            DropdownButton.Text = option
                        end
                    end
                    
                    function Dropdown:Refresh(newOptions, keepCurrent)
                        Dropdown.Options = newOptions
                        if not keepCurrent or not table.find(newOptions, Dropdown.Value) then
                            Dropdown.Value = newOptions[1]
                            DropdownButton.Text = newOptions[1]
                        end
                        updateOptions()
                    end
                    
                    return Dropdown
                end,
                
                -- CreateColorPicker
                CreateColorPicker = function(self, config)
                    local ColorPicker = {
                        Value = config.Color or Color3.fromRGB(255, 255, 255),
                        Frame = Utility:Create("Frame", {
                            Parent = Section.Container,
                            BackgroundTransparency = 1,
                            Size = {1, 0, 0, 40}
                        })
                    }
                    
                    Utility:Create("TextLabel", {
                        Parent = ColorPicker.Frame,
                        BackgroundTransparency = 1,
                        Position = {0, 0, 0, 0},
                        Size = {0.4, 0, 1, 0},
                        Text = config.Name,
                        TextColor3 = self.Colors.Text,
                        Font = Enum.Font.Gotham,
                        TextSize = 14,
                        TextXAlignment = Enum.TextXAlignment.Left
                    })
                    
                    local ColorButton = Utility:Create("TextButton", {
                        Parent = ColorPicker.Frame,
                        BackgroundColor3 = ColorPicker.Value,
                        BorderSizePixel = 0,
                        Position = {0.4, 10, 0.5, -15},
                        Size = {0.6, -20, 0, 30},
                        Text = "",
                        TextColor3 = self.Colors.Text,
                        Font = Enum.Font.Gotham,
                        TextSize = 14
                    })
                    
                    Utility:Create("UICorner", {
                        Parent = ColorButton,
                        CornerRadius = UDim.new(0, 4)
                    })
                    
                    ColorButton.MouseButton1Click:Connect(function()
                        -- Implementação básica de Color Picker
                        local r = tonumber(tostring(ColorPicker.Value.R * 255))
                        local g = tonumber(tostring(ColorPicker.Value.G * 255))
                        local b = tonumber(tostring(ColorPicker.Value.B * 255))
                        
                        local newR = math.clamp(r + 50, 0, 255)
                        local newG = math.clamp(g + 50, 0, 255)
                        local newB = math.clamp(b + 50, 0, 255)
                        
                        if newR > 200 then newR = 0 end
                        if newG > 200 then newG = 0 end
                        if newB > 200 then newB = 0 end
                        
                        ColorPicker.Value = Color3.fromRGB(newR, newG, newB)
                        ColorButton.BackgroundColor3 = ColorPicker.Value
                        
                        if config.Callback then
                            config.Callback(ColorPicker.Value)
                        end
                    end)
                    
                    function ColorPicker:Set(color)
                        ColorPicker.Value = color
                        ColorButton.BackgroundColor3 = color
                    end
                    
                    return ColorPicker
                end,
                
                -- CreateInput
                CreateInput = function(self, config)
