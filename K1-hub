-- MÓDULO 2: SISTEMA DE CRIPTOGRAFIA
-- ============================================
local EncryptionSystem = {
    -- Criptografar string
    Encrypt = function(self, text, key)
        if not GlobalConfig.Security.EncryptionEnabled then return text end
        local key = key or GlobalConfig.Security.EncryptionKey
        local encrypted = ""
        for i = 1, #text do
            local charCode = string.byte(text, i)
            local keyChar = string.byte(key, ((i - 1) % #key) + 1)
            encrypted = encrypted .. string.char(bit32.bxor(charCode, keyChar))
        end
        return game:GetService("HttpService"):Base64Encode(encrypted)
    end,
    
    -- Descriptografar string
    Decrypt = function(self, encrypted, key)
        if not GlobalConfig.Security.EncryptionEnabled then return encrypted end
        local key = key or GlobalConfig.Security.EncryptionKey
        local decoded = game:GetService("HttpService"):Base64Decode(encrypted)
        local decrypted = ""
        for i = 1, #decoded do
            local charCode = string.byte(decoded, i)
            local keyChar = string.byte(key, ((i - 1) % #key) + 1)
            decrypted = decrypted .. string.char(bit32.bxor(charCode, keyChar))
        end
        return decrypted
    end,
    
    -- Hash MD5 simples
    HashMD5 = function(self, text)
        local hash = 0
        for i = 1, #text do
            hash = bit32.bxor(hash, string.byte(text, i))
            hash = bit32.lshift(hash, 1)
        end
        return string.format("%x", hash)
    end,
    
    -- Gerar chave aleatória
    GenerateKey = function(self, length)
        local length = length or 32
        local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*()"
        local key = ""
        for i = 1, length do
            local rand = math.random(1, #chars)
            key = key .. string.sub(chars, rand, rand)
        end
        return key
    end
}

