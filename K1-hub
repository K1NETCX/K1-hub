-- ============================================
local ScriptSystem = {
    Scripts = {},
    Categories = {},
    RunningScripts = {},
    ScriptHistory = {},
    
    -- Categorias disponíveis
    CategoriesList = {
        "Player", "Movement", "Combat", "ESP", "Farm", "Admin", 
        "Visuals", "Misc", "Beta", "Experimental", "Custom"
    },
    
    -- Registrar script
    Register = function(self, scriptData)
        scriptData.id = #self.Scripts + 1
        scriptData.created = os.time()
        scriptData.executions = 0
        scriptData.rating = 0
        scriptData.totalRatings = 0
        
        table.insert(self.Scripts, scriptData)
        
        if not self.Categories[scriptData.category] then
            self.Categories[scriptData.category] = {}
        end
        table.insert(self.Categories[scriptData.category], scriptData)
        
        GlobalConfig.HubInfo.TotalScripts = #self.Scripts
        return scriptData.id
    end,
    
    -- Executar script
    Execute = function(self, scriptId, args)
        local script = self.Scripts[scriptId]
        if not script then
            MessageSystem:Error(string.format(GlobalConfig.Messages.ScriptNotFound, scriptId))
            return false
        end
        
        -- Verificar permissão pela key system
        if KeySystem.Status == "valid" and not KeySystem:HasFeature(script.requiredFeature or "all_scripts") then
            MessageSystem:Error("Você não tem permissão para executar este script!")
            return false
        end
        
        -- Criar thread segura
        local thread = coroutine.create(function()
            local success, result = pcall(function()
                if script.type == "url" then
                    local content = game:HttpGet(script.url)
                    loadstring(content)()
                elseif script.type == "function" then
                    script.function(args)
                elseif script.type == "code" then
                    loadstring(script.code)()
                end
            end)
            
            script.executions = script.executions + 1
            
            if success then
                MessageSystem:Success(string.format(GlobalConfig.Messages.ScriptExecuted, script.name))
                self:AddToHistory(scriptId, true)
            else
                MessageSystem:Error(string.format(GlobalConfig.Messages.ScriptFailed, result))
                self:AddToHistory(scriptId, false, result)
            end
        end)
        
        coroutine.resume(thread)
        return true
    end,
    
    -- Parar script
    Stop = function(self, scriptId)
        if self.RunningScripts[scriptId] then
            self.RunningScripts[scriptId] = false
            MessageSystem:Info(string.format(GlobalConfig.Messages.ScriptStopped, self.Scripts[scriptId].name))
            return true
        end
        return false
    end,
    
    -- Adicionar ao histórico
    AddToHistory = function(self, scriptId, success, error)
        local history = {
            scriptId = scriptId,
            scriptName = self.Scripts[scriptId].name,
            timestamp = os.time(),
            success = success,
            error = error
        }
        
        table.insert(self.ScriptHistory, 1, history)
        
        -- Manter apenas últimos 100
        if #self.ScriptHistory > 100 then
            table.remove(self.ScriptHistory)
        end
        
        -- Salvar histórico
        self:SaveHistory()
    end,
    
    -- Salvar histórico
    SaveHistory = function(self)
        local historyData = {
            history = self.ScriptHistory,
            lastUpdate = os.time()
        }
        local encoded = game:GetService("HttpService"):JSONEncode(historyData)
        FileSystem:Save("script_history.json", encoded)
    end,
    
    -- Carregar histórico
    LoadHistory = function(self)
        local data = FileSystem:Load("script_history.json")
        if data then
            local decoded = game:GetService("HttpService"):JSONDecode(data)
            if decoded and decoded.history then
                self.ScriptHistory = decoded.history
            end
        end
    end,
    
    -- Avaliar script
    RateScript = function(self, scriptId, rating)
        local script = self.Scripts[scriptId]
        if script then
            script.rating = (script.rating * script.totalRatings + rating) / (script.totalRatings + 1)
            script.totalRatings = script.totalRatings + 1
            return true
        end
        return false
    end,
    
    -- Buscar scripts
    Search = function(self, query)
        query = string.lower(query)
        local results = {}
        
        for _, script in ipairs(self.Scripts) do
            if string.find(string.lower(script.name), query) or
               string.find(string.lower(script.description or ""), query) or
               string.find(string.lower(script.category), query) then
                table.insert(results, script)
            end
        end
        
        return results
    end
}

