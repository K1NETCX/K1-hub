-- 🧹 SISTEMA MAID / JANITOR (Prevenção de Memory Leaks)
-- ═══════════════════════════════════════════════════════════════════════════
local Maid = {}
Maid.__index = Maid

function Maid.new()
    local self = setmetatable({}, Maid)
    self._tasks = {}
    self._connections = {}
    self._instances = {}
    return self
end

function Maid:AddTask(task)
    table.insert(self._tasks, task)
end

function Maid:AddConnection(connection, event)
    table.insert(self._connections, connection)
    return connection
end

function Maid:AddInstance(instance)
    table.insert(self._instances, instance)
    return instance
end

function Maid:Destroy()
    for _, task in ipairs(self._tasks) do
        if type(task) == "function" then task() end
    end
    for _, connection in ipairs(self._connections) do
        if connection and connection.Disconnect then connection:Disconnect() end
    end
    for _, instance in ipairs(self._instances) do
        if instance and instance.Destroy then instance:Destroy() end
    end
    self._tasks = nil
    self._connections = nil
    self._instances = nil
end

