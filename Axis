-- ═══════════════════════════════════════════════════════════════════════════
-- 🖱️ SISTEMA DE DRAG & DROP (Smooth Dragging com Interpolação)
-- ═══════════════════════════════════════════════════════════════════════════
function Window:SetupDragging()
    local dragData = {
        active = false,
        startPos = nil,
        startMousePos = nil,
    }
    
    -- Explicação matemática:
    -- O arrasto suave é implementado calculando a diferença entre a posição atual do mouse
    -- e a posição inicial do clique. Essa diferença é somada à posição original da janela.
    -- Usamos RenderStepped para interpolação natural a 60fps, evitando "tearing" visual.
    
    local function updateDrag()
        if not dragData.active then return end
        
        local delta = UserInputService:GetMouseLocation() - dragData.startMousePos
        local newPos = UDim2.new(0, dragData.startPos.X.Offset + delta.X, 0, dragData.startPos.Y.Offset + delta.Y)
        
        -- Limites para evitar que a janela saia da tela
        local maxX = 0
        local maxY = 0
        local viewportSize = workspace.CurrentCamera.ViewportSize
        
        if newPos.X.Offset < -self.MainFrame.AbsoluteSize.X + 50 then
            newPos = UDim2.new(0, -self.MainFrame.AbsoluteSize.X + 50, newPos.Y.Offset, newPos.Y.Offset)
        end
        if newPos.X.Offset > viewportSize.X - 50 then
            newPos = UDim2.new(0, viewportSize.X - 50, newPos.Y.Offset, newPos.Y.Offset)
        end
        if newPos.Y.Offset < 0 then
            newPos = UDim2.new(newPos.X.Offset, newPos.X.Offset, 0, 0)
        end
        if newPos.Y.Offset > viewportSize.Y - self.MainFrame.AbsoluteSize.Y + 50 then
            newPos = UDim2.new(newPos.X.Offset, newPos.X.Offset, 0, viewportSize.Y - self.MainFrame.AbsoluteSize.Y + 50)
        end
        
        self.MainFrame.Position = newPos
    end
    
    local connection
    local function startDrag(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mousePos = UserInputService:GetMouseLocation()
            local framePos = self.MainFrame.AbsolutePosition
            
            if mousePos.X >= framePos.X and mousePos.X <= framePos.X + self.MainFrame.AbsoluteSize.X and
               mousePos.Y >= framePos.Y and mousePos.Y <= framePos.Y + 65 then
                dragData.active = true
                dragData.startPos = self.MainFrame.Position
                dragData.startMousePos = mousePos
                connection = RunService.RenderStepped:Connect(updateDrag)
            end
        end
    end
    
    local function stopDrag()
        dragData.active = false
        if connection then connection:Disconnect() end
    end
    
    self.Maid:AddConnection(UserInputService.InputBegan:Connect(startDrag))
    self.Maid:AddConnection(UserInputService.InputEnded:Connect(stopDrag))
end

function Window:SetupButtonEvents()
    -- Efeitos hover e click nos botões
    local function setupButton(button, hoverColor, clickScale)
        button.MouseEnter:Connect(function()
            Animate(button, {BackgroundTransparency = 0.1}, 0.2)
        end)
        button.MouseLeave:Connect(function()
            Animate(button, {BackgroundTransparency = 0.3}, 0.2)
        end)
        button.MouseButton1Click:Connect(function()
            AnimateBounce(button, {Size = UDim2.new(button.Size.X.Scale, button.Size.X.Offset, 0.9, button.Size.Y.Offset)})
            task.wait(0.08)
            AnimateBounce(button, {Size = UDim2.new(button.Size.X.Scale, button.Size.X.Offset, 1, button.Size.Y.Offset)})
        end)
    end
    
    setupButton(self.MinimizeButton)
    setupButton(self.CloseButton)
    
    self.MinimizeButton.MouseButton1Click:Connect(function()
        self:Minimize()
    end)
    
    self.CloseButton.MouseButton1Click:Connect(function()
        self:Destroy()
    end)
end

function Window:Minimize()
    local isMinimized = self.MainFrame.Size.Y.Scale == 0
    if isMinimized then
        Animate(self.MainFrame, {Size = UDim2.new(0, 800, 0, 550), Position = UDim2.new(0.5, -400, 0.5, -275)}, 0.3, EasingStyles.Elastic, EasingDirections.Out)
        self.ContentContainer.Visible = true
    else
        Animate(self.MainFrame, {Size = UDim2.new(0, 800, 0, 65), Position = UDim2.new(0.5, -400, 0, 0)}, 0.3)
        self.ContentContainer.Visible = false
    end
end

function Window:CreateTab(name, icon)
    local tab = {}
    tab.Name = name
    tab.Icon = icon or "📄"
    tab.Window = self
    tab.Components = {}
    tab.Maid = Maid.new()
    
    -- Botão da aba na sidebar
    tab.Button = Instance.new("TextButton")
    tab.Button.Name = "Tab_" .. name:gsub("%s+", "")
    tab.Button.Size = UDim2.new(0.85, 0, 0, 45)
    tab.Button.BackgroundColor3 = Theme.Surface
    tab.Button.BackgroundTransparency = 0.5
    tab.Button.Text = tab.Icon .. "  " .. name
    tab.Button.TextColor3 = Theme.TextSecondary
    tab.Button.TextSize = 14
    tab.Button.Font = Enum.Font.GothamSemibold
    tab.Button.BorderSizePixel = 0
    tab.Button.Parent = self.Sidebar
    
    local buttonCorner = Instance.new("UICorner")
    buttonCorner.CornerRadius = UDim.new(0, 10)
    buttonCorner.Parent = tab.Button
    
    -- Página de conteúdo
    tab.Page = Instance.new("ScrollingFrame")
    tab.Page.Name = "Page_" .. name:gsub("%s+", "")
    tab.Page.Size = UDim2.new(1, -20, 1, -20)
    tab.Page.Position = UDim2.new(0, 10, 0, 10)
    tab.Page.BackgroundTransparency = 1
    tab.Page.BorderSizePixel = 0
    tab.ScrollThickness = 6
    tab.Page.ScrollBarImageColor3 = Theme.Primary
    tab.Page.ScrollBarThickness = 8
    tab.Page.Visible = false
    tab.Page.Parent = self.PagesContainer
    
    local pageLayout = Instance.new("UIListLayout")
    pageLayout.Padding = UDim.new(0, 12)
    pageLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    pageLayout.Parent = tab.Page
    
    local pagePadding = Instance.new("UIPadding")
    pagePadding.PaddingTop = UDim.new(0, 10)
    pagePadding.PaddingBottom = UDim.new(0, 10)
    pagePadding.Parent = tab.Page
    
    -- Evento de clique na aba
    local function selectTab()
        if self.ActiveTab then
            Animate(self.ActiveTab.Button, {BackgroundTransparency = 0.5, TextColor3 = Theme.TextSecondary}, 0.2)
            Animate(self.ActiveTab.Page, {BackgroundTransparency = 1}, 0.15, nil, nil, function()
                self.ActiveTab.Page.Visible = false
            end)
        end
        
        self.ActiveTab = tab
        Animate(tab.Button, {BackgroundTransparency = 0.2, TextColor3 = Theme.TextPrimary}, 0.2)
        
        tab.Page.Visible = true
        Animate(tab.Page, {BackgroundTransparency = 0}, 0.3)
        
        -- Efeito de fade in
        for _, child in ipairs(tab.Page:GetChildren()) do
            if child:IsA("GuiObject") then
                child.BackgroundTransparency = 1
                Animate(child, {BackgroundTransparency = child.BackgroundTransparency - 0.5}, 0.2)
            end
        end
    end
    
    tab.Button.MouseButton1Click:Connect(selectTab)
    
    -- Selecionar primeira aba automaticamente
    if #self.Tabs == 0 then
        selectTab()
    end
    
    table.insert(self.Tabs, tab)
    
    -- Métodos para adicionar componentes à aba
    function tab:CreateButton(text, callback)
        return self.Window:CreateButton(self, text, callback)
    end
    
    function tab:CreateToggle(text, default, callback)
        return self.Window:CreateToggle(self, text, default, callback)
    end
    
    function tab:CreateSlider(text, min, max, default, callback)
        return self.Window:CreateSlider(self, text, min, max, default, callback)
    end
    
    function tab:CreateDropdown(text, options, callback)
        return self.Window:CreateDropdown(self, text, options, callback)
    end
    
    function tab:CreateTextbox(text, placeholder, callback)
        return self.Window:CreateTextbox(self, text, placeholder, callback)
    end
    
    function tab:CreateSection(text)
        return self.Window:CreateSection(self, text)
    end
    
    return tab
end

