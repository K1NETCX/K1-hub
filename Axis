function ModernUI:Notify(title, message, duration, type)
    type = type or "info"
    duration = duration or 3
    
    local colors = {
        success = Theme.Success,
        error = Theme.Accent,
        warning = Theme.Warning,
        info = Theme.Primary,
    }
    
    local notification = Instance.new("Frame")
    notification.Size = UDim2.new(0, 300, 0, 0)
    notification.BackgroundColor3 = Theme.Surface
    notification.BackgroundTransparency = 0.1
    notification.ClipsDescendants = true
    notification.BorderSizePixel = 0
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = notification
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = colors[type] or Theme.Primary
    stroke.Thickness = 2
    stroke.Transparency = 0.5
    stroke.Parent = notification
    
    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, colors[type] or Theme.Primary),
        ColorSequenceKeypoint.new(1, (colors[type] or Theme.Primary):Lerp(Theme.Surface, 0.8)),
    })
    gradient.Transparency = ColorSequence.new({
        ColorSequenceKeypoint.new(0, 0.7),
        ColorSequenceKeypoint.new(1, 0.95),
    })
    gradient.Rotation = 45
    gradient.Parent = notification
    
    local icon = Instance.new("TextLabel")
    icon.Size = UDim2.new(0, 40, 1, 0)
    icon.BackgroundTransparency = 1
    icon.Text = type == "success" and "✓" or type == "error" and "✕" or type == "warning" and "⚠" or "ℹ"
    icon.TextColor3 = colors[type] or Theme.Primary
    icon.TextSize = 24
    icon.Font = Enum.Font.GothamBold
    icon.Parent = notification
    
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -50, 0, 25)
    titleLabel.Position = UDim2.new(0, 50, 0, 5)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = title
    titleLabel.TextColor3 = Theme.TextPrimary
    titleLabel.TextSize = 14
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = notification
    
    local messageLabel = Instance.new("TextLabel")
    messageLabel.Size = UDim2.new(1, -50, 0, 35)
    messageLabel.Position = UDim2.new(0, 50, 0, 30)
    messageLabel.BackgroundTransparency = 1
    messageLabel.Text = message
    messageLabel.TextColor3 = Theme.TextSecondary
    messageLabel.TextSize = 12
    messageLabel.Font = Enum.Font.Gotham
    messageLabel.TextXAlignment = Enum.TextXAlignment.Left
    messageLabel.TextWrapped = true
    messageLabel.Parent = notification
    
    -- Encontrar o container de notificações
    local container = nil
    for _, gui in ipairs(LocalPlayer.PlayerGui:GetChildren()) do
        if gui.Name == "ModernUILibrary" then
            for _, child in ipairs(gui:GetChildren()) do
                if child.Name == "NotificationContainer" then
                    container = child
                    break
                end
            end
        end
    end
    
    if container then
        notification.Parent = container
        
        -- Animação de entrada
        notification.Size = UDim2.new(0, 300, 0, 0)
        notification.Position = UDim2.new(1, 0, 0, 0)
        notification.BackgroundTransparency = 1
        
        Animate(notification, {Size = UDim2.new(0, 300, 0, 70), Position = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 0.1}, 0.3, EasingStyles.Standard, EasingDirections.Out)
        
        -- Auto destruir
        task.delay(duration, function()
            if notification and notification.Parent then
                Animate(notification, {Size = UDim2.new(0, 300, 0, 0), Position = UDim2.new(1, 0, 0, 0)}, 0.3, EasingStyles.Standard, EasingDirections.In, function()
                    pcall(function() notification:Destroy() end)
                end)
            end
        end)
    end
end

