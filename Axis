-- 📦 CLASSE BASE PARA COMPONENTES
-- ═══════════════════════════════════════════════════════════════════════════
local Component = {}
Component.__index = Component

function Component.new()
    local self = setmetatable({}, Component)
    self.Maid = Maid.new()
    self.Instances = {}
    self.Connections = {}
    return self
end

function Component:CreateInstance(className, properties, parent)
    local instance = Instance.new(className)
    for prop, value in pairs(properties or {}) do
        instance[prop] = value
    end
    if parent then instance.Parent = parent end
    table.insert(self.Instances, instance)
    return instance
end

function Component:Destroy()
    if self.Maid then self.Maid:Destroy() end
    for _, instance in ipairs(self.Instances) do
        if instance and instance.Destroy then pcall(function() instance:Destroy() end) end
    end
    self.Instances = nil
    self.Connections = nil
end

